# HarmonyOS 项目 .gitignore

# ========== 构建输出 ==========
# 构建生成的文件，不需要上传
build/
entry/build/
.hvigor/
oh_modules/

# ========== IDE 配置 ==========
# DevEco Studio IDE 配置（包含本地路径和缓存）
.idea/
*.iml

# ========== 预览和测试缓存 ==========
# 预览生成的临时文件
entry/.preview/

# ========== 日志文件 ==========
*.log
*.log.*

# ========== 系统文件 ==========
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~

# ========== 敏感文件 ==========
# 签名证书和密钥文件（绝对不能上传）
*.p12
*.cer
*.p7b
*.jks
*.keystore

# ========== 其他 ==========
# 临时文件
*.tmp
*.temp
*.swp
*.swo

# 备份文件
*.bak
*.backup
*.old

# 压缩文件
*.zip
*.rar
*.7z
*.tar
*.gz

# ========== HarmonyOS 特定 ==========
# 本地配置文件（包含本地路径）
local.properties
oh-package-lock.json5

# 临时输出文件
output.txt
temp_index.txt
onmove_match.txt
